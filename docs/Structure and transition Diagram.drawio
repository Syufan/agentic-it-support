        <mxCell id="TxyA0oDUsuyIZvyDspSO-101" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;strokeWidth=1.5;absoluteArcSize=1;" value="&lt;b&gt;Transition Rules&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;p class=&quot;p1&quot;&gt;T1&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INTAKE + ASK_USER → CLARIFYING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T2&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INTAKE + CALL_TOOL → INVESTIGATING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T3&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;CLARIFYING + ASK_USER → CLARIFYING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T4&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;CLARIFYING + CALL_TOOL → INVESTIGATING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T5&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INVESTIGATING + CALL_TOOL → INVESTIGATING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T6&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INVESTIGATING + ASK_USER → CLARIFYING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T7&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INVESTIGATING + RESOLVE → RESOLVING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T8&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;INVESTIGATING + ESCALATE → ESCALATING&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T9&amp;nbsp;&lt;span class=&quot;Apple-converted-space&quot;&gt;&amp;nbsp;&lt;/span&gt;RESOLVING + confirmed=True → CLOSED&lt;/p&gt;&lt;p class=&quot;p1&quot;&gt;T10 RESOLVING + confirmed=False + attempts remain → INVESTIGATING&lt;/p&gt;&lt;p class=&quot;p1&quo